# ============================================
# Fintrix — backend environment variables
# Copy to .env and fill in real values.
# ============================================

# --- Server ---
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# --- Auth secrets (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))") ---
JWT_SECRET=replace-me
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_EXPIRE=7d
CSRF_SECRET=replace-me
API_KEY=replace-me
SESSION_SECRET=replace-me
ENCRYPTION_KEY=replace-me-with-64-hex-chars

# --- Frontend / CORS ---
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# --- Database (Neon / any Postgres) ---
DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# --- Cache (Upstash REST) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=
REDIS_ENABLED=true

# --- AI providers (the chain tries each in order) ---
AI_PROVIDER=groq
AI_TIMEOUT=15000
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
HUGGINGFACE_API_KEY=
HUGGINGFACE_TOKEN=
ANTHROPIC_API_KEY=
AI_URL=http://127.0.0.1:8000

# --- Realtime ---
SOCKET_PATH=/socket.io
SOCKET_CORS=http://localhost:5173

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=fintrix
CLOUDINARY_SECURE=true

# --- Email ---
EMAIL_PROVIDER=log
EMAIL_FROM=noreply@fintrix.local
EMAIL_USER=
EMAIL_PASS=
EMAIL_SERVICE=gmail
SMTP_HOST=
SMTP_PORT=1025
SMTP_SECURE=false

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Blockchain ---
BLOCKCHAIN_NETWORK=sepolia
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
BLOCKCHAIN_CHAIN_ID=11155111

# --- Cron ---
FOLLOWUP_CRON=0 9 * * *
FOLLOWUP_CRON_ENABLED=true

# --- Rate limiting ---
RATE_LIMIT_GLOBAL=600
RATE_LIMIT_AUTH=20

# --- Logging ---
LOG_LEVEL=info
